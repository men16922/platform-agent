AWS_REGION=ap-northeast-2
ENVIRONMENT=local

# Slack interactive approval (see docs/SLACK_APP_SETUP.md)
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
APPROVAL_REQUEST_TABLE=incident-approval-requests
APPROVAL_DEFAULT_DECISION=reject
APPROVAL_REQUEST_TTL_SEC=86400

# AI / LLM
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5

# GCP — ADK (Vertex AI, API Key 불필요: gcloud auth application-default login)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast3
GCP_PROJECT=
GCP_REGION=asia-northeast3

# Azure — MS Agent Framework (az login 또는 API Key)
AZURE_AI_PROJECT_ENDPOINT=
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_REGION=koreacentral
AZURE_RESOURCE_GROUP=

# Overnight harness engines
CLAUDE_CODE_BIN=
CODEX_CLI_BIN=
