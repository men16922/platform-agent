          ~ <<-EOT
                # Low-footprint Argo CD for local kind/k3s. Contract (guard-tested): every CPU
                # request stays <= 50m so the full add-on stack fits the Docker VM budget.
                # Dex (SSO) and notifications are off — local access is port-forward + admin.
                
                dex:
                  enabled: false
                
                notifications:
                  enabled: false
                
              + # Track managed resources by annotation, not the app.kubernetes.io/instance
              + # label. The platform-agent chart already sets that label to its release name,
              + # so label tracking would collide (ArgoCD's official guidance for Helm charts
              + # that stamp the instance label). Required for Phase 3 to adopt the workload.
              + configs:
              +   cm:
              +     application.resourceTrackingMethod: annotation
