# demo (default) or aws
DASHBOARD_DATA_SOURCE=demo

# Required only when DASHBOARD_DATA_SOURCE=aws
PLATFORM_AWS_REGION=us-east-1
DASHBOARD_INCIDENT_TABLE=incident-history
DASHBOARD_ACTIVITY_TABLE=platform-agent-activity
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/platform-agent-vercel-dashboard-read

# Auth (required for write/approval UI — Phase 1)
# AUTH_SECRET=<random-32-byte-secret>
# AUTH_GITHUB_ID=<oauth-app-client-id>
# AUTH_GITHUB_SECRET=<oauth-app-client-secret>
# AUTH_TRUST_HOST=true
# AUTH_ALLOWED_ORG=<github-org-slug>
# AUTH_ADMIN_USERS=<comma-separated-github-usernames>
