# demo (default) or aws
DASHBOARD_DATA_SOURCE=demo

# Required only when DASHBOARD_DATA_SOURCE=aws
PLATFORM_AWS_REGION=us-east-1
DASHBOARD_INCIDENT_TABLE=incident-history
DASHBOARD_ACTIVITY_TABLE=platform-agent-activity
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/platform-agent-vercel-dashboard-read

# Auth (required for write/approval UI — Phase 1)
# AUTH_SECRET=<random-32-byte-secret>
# AUTH_GITHUB_ID=<oauth-app-client-id>
# AUTH_GITHUB_SECRET=<oauth-app-client-secret>
# AUTH_TRUST_HOST=true
# AUTH_ALLOWED_ORG=<github-org-slug>
# AUTH_ADMIN_USERS=<comma-separated-github-usernames>

# Local-dev sign-in (NEVER set in production / on Vercel).
# When DASHBOARD_DEV_AUTH=1 AND not running on Vercel, a "Local Dev (no GitHub)"
# credentials provider is added that signs you in as admin — use it when GitHub
# OAuth callbacks are bound to the production domain and can't complete on
# localhost. Still needs AUTH_SECRET + AUTH_TRUST_HOST=true set locally.
# DASHBOARD_DEV_AUTH=1

# Natural-language deploy: URL of the local AI Model Router API
# (uvicorn src.agents.ai.local_deploy_api:app --port 8077)
# LOCAL_DEPLOY_API_URL=http://127.0.0.1:8077
