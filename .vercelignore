# Vercel project Root Directory = dashboard/
# Excludes non-dashboard content from deploy upload (CLI --archive=tgz and Git).
# IMPORTANT: patterns are gitignore-style — unanchored `src/` matches at ANY depth,
# including dashboard/src/, which silently produced a routeless 404-only build on
# every Git deployment. Keep repo-root excludes anchored with a leading `/`.

# Python (repo root only)
/src/
/tests/
/scripts/
/infra/
/examples/
*.py
*.pyc
__pycache__/
.venv/
.venv-mlx/
.venv*/
*.metallib
*.egg-info/

# Docs (not needed for build)
/docs/

# Agent configs
/.claude/
/.kiro/
/.codex/

# Build artifacts
dashboard/.next/
dashboard/node_modules/
dashboard/.env.local
