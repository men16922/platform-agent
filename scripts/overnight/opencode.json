{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "webfetch": "deny",
    "bash": {
      "*": "ask",
      "git push *": "deny",
      "git reset --hard *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "make deploy*": "deny",
      "make publish*": "deny",
      "make release*": "deny",
      "make db-*": "deny",
      "make infra-*": "deny",
      "make check": "allow",
      "make test": "allow",
      "make lint": "allow",
      "make typecheck": "allow",
      "make build": "allow",
      "make smoke-local": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git restore *": "allow",
      "git checkout -- *": "allow",
      "python3 *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "touch scripts/overnight/*": "allow"
    }
  }
}
